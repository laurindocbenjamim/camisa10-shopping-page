# VITE_API_BASE_URL: Public URL of the backend API.
# In production (Railway), set this as a Build Variable in the Railway dashboard.
# Example: https://my-backend.up.railway.app/api/v1
# NEVER use localhost here for deployed environments — it points to the container itself.
VITE_API_BASE_URL="https://your-backend.up.railway.app/api/v1"
